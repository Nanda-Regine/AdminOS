{
  "crons": [
    {
      "path": "/api/cron/daily-brief",
      "schedule": "0 3 * * 1-5"
    },
    {
      "path": "/api/cron/debt-recovery",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/wellness",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/fan-out-brief",
      "schedule": "0 5 * * 1-5"
    },
    {
      "path": "/api/cron/fan-out-wellness",
      "schedule": "0 6 * * 1-5"
    },
    {
      "path": "/api/cron/process-queue",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/escalate-conversations",
      "schedule": "0 10 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://adminos.co.za"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, x-tenant-id"
        }
      ]
    }
  ]
}
