# ── SUPABASE ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=           # Project URL from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # Anon (public) key — safe to expose in client code
SUPABASE_SERVICE_ROLE_KEY=          # Service role key — NEVER expose client-side, server only

# ── ANTHROPIC ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                  # From console.anthropic.com → API Keys
# Models in use: claude-sonnet-4-6 (inbox/wellness), claude-haiku-4-5-20251001 (debt/docs/brief)

# ── 360DIALOG WHATSAPP BUSINESS API ───────────────────────────────────────────
DIALOG360_API_KEY=                  # Per-tenant key from 360dialog partner hub
DIALOG360_WEBHOOK_SECRET=           # HMAC secret for inbound webhook verification
# Note: each tenant has their own API key stored in tenants.whatsapp_api_key (DB)
# DIALOG360_API_KEY here is for the super-admin / fallback tenant

# ── EMAIL ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=                     # From resend.com → API Keys
RESEND_FROM_EMAIL=noreply@adminos.co.za  # Must be a verified domain sender

# ── REDIS (Upstash) ───────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=             # From console.upstash.com → REST URL
UPSTASH_REDIS_REST_TOKEN=           # REST token (not the redis:// connection string)

# ── INNGEST ───────────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=                  # From app.inngest.com → Manage → Event Keys
INNGEST_SIGNING_KEY=                # From app.inngest.com → Manage → Signing Key
# Local dev: run `npx inngest-cli@latest dev` alongside `npm run dev`

# ── PAYFAST PAYMENTS ──────────────────────────────────────────────────────────
PAYFAST_MERCHANT_ID=                # From PayFast → Settings → Merchant Details
PAYFAST_MERCHANT_KEY=               # Merchant key (10 chars)
PAYFAST_PASSPHRASE=                 # Optional — must match PayFast dashboard if set
# Webhook ITN URL: https://adminos.co.za/api/billing/webhook
# Test mode: use sandbox.payfast.co.za with test credentials

# ── XERO INTEGRATION ──────────────────────────────────────────────────────────
XERO_CLIENT_ID=                     # From developer.xero.com → My Apps
XERO_CLIENT_SECRET=                 # App secret
# Redirect URI must be registered: https://adminos.co.za/api/xero/callback

# ── LOAD SHEDDING ─────────────────────────────────────────────────────────────
ESKOMSEPUSH_API_KEY=                # From eskomsepush.com/developers (free tier: 50 req/day)

# ── SECURITY ──────────────────────────────────────────────────────────────────
CRON_SECRET=                        # openssl rand -hex 32 — set in Vercel + here
# All /api/cron/* routes require: Authorization: Bearer $CRON_SECRET

# ── ANALYTICS (optional) ──────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=            # From posthog.com (user behaviour analytics)
NEXT_PUBLIC_GA4_ID=                 # Google Analytics 4 measurement ID (G-XXXXXXXX)

# ── MONITORING (optional) ─────────────────────────────────────────────────────
SENTRY_DSN=                         # From sentry.io (server-side error tracking)
NEXT_PUBLIC_SENTRY_DSN=             # Same DSN — used by client-side Sentry

# ── LOCAL DEV ONLY ────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# For Google OAuth redirect in dev, add http://localhost:3000/auth/callback
# to Supabase → Authentication → URL Configuration → Redirect URLs
