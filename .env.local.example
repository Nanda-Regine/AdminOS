# ⚠️  DO NOT commit this file with real values.
# ⚠️  PAYFAST_SANDBOX must be "false" in production.
#     A wrong value here = real users paying into sandbox = money not received.
#
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local

# ─── SUPABASE ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=           # supabase.com → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # Anon (public) key — safe to expose in client code
SUPABASE_SERVICE_ROLE_KEY=          # Service role key — SERVER-ONLY. Never expose client-side, never commit.
# Models in use: claude-sonnet-4-6 (inbox/wellness), claude-haiku-4-5-20251001 (debt/docs/brief)

# ─── ANTHROPIC ───────────────────────────────────────────────
ANTHROPIC_API_KEY=                  # console.anthropic.com → API Keys

# ─── META WHATSAPP BUSINESS API ──────────────────────────────
META_WHATSAPP_ACCESS_TOKEN=         # developers.facebook.com → App → WhatsApp → API Setup → Temporary/Permanent Token
META_PHONE_NUMBER_ID=               # developers.facebook.com → App → WhatsApp → Phone Number ID
META_WEBHOOK_SECRET=                # The Verify Token you set in Meta App Dashboard → Webhooks
                                    # Used for HMAC-SHA256 x-hub-signature-256 verification on inbound messages

# ─── EMAIL (RESEND) ──────────────────────────────────────────
RESEND_API_KEY=                     # resend.com → API Keys
RESEND_FROM_EMAIL=noreply@adminos.co.za  # Must be a verified domain sender in Resend

# ─── UPSTASH REDIS ───────────────────────────────────────────
UPSTASH_REDIS_REST_URL=             # console.upstash.com → Database → REST API → REST URL
UPSTASH_REDIS_REST_TOKEN=           # REST token (not the redis:// connection string)

# ─── INNGEST ─────────────────────────────────────────────────
INNGEST_EVENT_KEY=                  # app.inngest.com → your app → Manage → Event Keys
INNGEST_SIGNING_KEY=                # app.inngest.com → your app → Manage → Signing Key
# Local dev: run `npx inngest-cli@latest dev` alongside `npm run dev`

# ─── PAYMENTS (PAYFAST) ──────────────────────────────────────
PAYFAST_MERCHANT_ID=                # payfast.co.za → My Account → Merchant Details → Merchant ID
PAYFAST_MERCHANT_KEY=               # Merchant key (10 chars)
PAYFAST_PASSPHRASE=                 # Must match the passphrase set in PayFast dashboard (if set)
PAYFAST_SANDBOX=false               # CRITICAL: must be "false" in production!
                                    # Set "true" only for local testing with sandbox.payfast.co.za
# ITN webhook URL: https://adminos.co.za/api/billing/webhook

# ─── XERO INTEGRATION ────────────────────────────────────────
XERO_CLIENT_ID=                     # developer.xero.com → My Apps → your app → Client ID
XERO_CLIENT_SECRET=                 # App secret
# Redirect URI must be registered: https://adminos.co.za/api/xero/callback

# ─── CRON SECURITY ───────────────────────────────────────────
CRON_SECRET=                        # openssl rand -hex 32 — must match Vercel env var
# All /api/cron/* routes require: Authorization: Bearer $CRON_SECRET
# Vercel injects this automatically on scheduled invocations.

# ─── N8N FILE PIPELINE ───────────────────────────────────────
N8N_WEBHOOK_SECRET=                 # Shared secret for n8n → AdminOS /api/workflow/file-received
                                    # Set the same value in your n8n workflow HTTP Request node

# ─── APP CONFIG ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://adminos.co.za   # No trailing slash. Use http://localhost:3000 in dev.
                                            # Used for absolute URLs in emails and OG image tags.

# ─── LOAD SHEDDING ───────────────────────────────────────────
ESKOMSEPUSH_API_KEY=                # eskomsepush.com/developers (free tier: 50 req/day)

# ─── ANALYTICS (optional) ────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=            # posthog.com — user behaviour analytics
NEXT_PUBLIC_GA4_ID=                 # Google Analytics 4 measurement ID (G-XXXXXXXX)

# ─── MONITORING (optional) ───────────────────────────────────
SENTRY_DSN=                         # sentry.io — server-side error tracking
NEXT_PUBLIC_SENTRY_DSN=             # Same DSN — used by client-side Sentry

# ─── GOOGLE OAUTH (via Supabase) ─────────────────────────────
# No env vars needed here — Google OAuth is handled by Supabase's built-in provider.
# Configure in: supabase.com → your project → Auth → Providers → Google
# Add Supabase callback URL to Google OAuth console:
#   https://<your-project-ref>.supabase.co/auth/v1/callback
# For local dev, add http://localhost:3000/auth/callback to Supabase Redirect URLs.
